# Copy to .env.local and fill in. .env.local is git-ignored.

# Clerk publishable key (Clerk dashboard → API Keys). Safe for the client.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Convex deployment URL — printed by `npx convex dev` on first run.
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# --- Server-only secrets: set these in the CONVEX DASHBOARD, never here ---
# CLERK_JWT_ISSUER_DOMAIN = your Clerk Frontend API URL (https://xxx.clerk.accounts.dev)
# GEMINI_API_KEY          = (later, for voice-to-text)
