# --- Neon Postgres ---
# Pooled connection string from the Neon dashboard (includes ?sslmode=require).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Clerk (same Clerk app as the mobile project) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# Where Clerk routes auth in this web app.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/today"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/today"

# --- Web Push (VAPID) ---
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# Contact email used in the VAPID "subject" (mailto:).
VAPID_SUBJECT="mailto:you@example.com"

# --- Cron ---
# Shared secret; Vercel Cron sends it as a Bearer token to /api/cron/sweep-reminders.
CRON_SECRET=""
